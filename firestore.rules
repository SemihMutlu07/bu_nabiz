rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /posts/{postId} {
      allow read: if true;

      allow create: if
        // Required fields
        request.resource.data.keys().hasAll([
          'week', 'status', 'intensity', 'me_too_count', 'created_at'
        ]) &&
        // week is a non-empty string
        request.resource.data.week is string &&
        request.resource.data.week.size() > 0 &&
        // category optional: null or from whitelist
        (
          !('category' in request.resource.data) ||
          request.resource.data.category == null ||
          request.resource.data.category in ['ders', 'proje', 'basvuru', 'hayat']
        ) &&
        // status from whitelist
        request.resource.data.status in [
          'yetismiyor', 'odak_yok', 'tikandim', 'yorgun', 'kaygili', 'idare_eder'
        ] &&
        // intensity integer 1..5
        request.resource.data.intensity is int &&
        request.resource.data.intensity >= 1 &&
        request.resource.data.intensity <= 5 &&
        // me_too_count must start at 0
        request.resource.data.me_too_count == 0 &&
        // created_at must be the server timestamp
        request.resource.data.created_at == request.time &&
        // custom_text optional: null or string <= 160 chars
        (
          !('custom_text' in request.resource.data) ||
          request.resource.data.custom_text == null ||
          (
            request.resource.data.custom_text is string &&
            request.resource.data.custom_text.size() <= 160
          )
        ) &&
        // micro_step optional: null or string
        (
          !('micro_step' in request.resource.data) ||
          request.resource.data.micro_step == null ||
          request.resource.data.micro_step is string
        );

      // Only me_too_count may be incremented by exactly 1.
      // Use changedKeys() — affectedKeys() misses transform-only writes.
      allow update: if
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['me_too_count']) &&
        request.resource.data.me_too_count == resource.data.me_too_count + 1;

      allow delete: if false;
    }

    match /me_too_events/{eventId} {
      allow read: if true;

      // PostCard writes: post_id, fingerprint_hash, created_at (serverTimestamp)
      // No 'week' field; field is 'fingerprint_hash' not 'fingerprint'.
      allow create: if
        request.resource.data.keys().hasAll(['post_id', 'fingerprint_hash', 'created_at']) &&
        request.resource.data.post_id is string &&
        request.resource.data.fingerprint_hash is string &&
        request.resource.data.created_at == request.time;

      allow update, delete: if false;
    }
  }
}
